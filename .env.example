# CryptoCopilot — environment template. Copy to .env and fill in the two free keys:
#   cp -n .env.example .env   (cp -n will NOT overwrite an existing .env)
# .env is gitignored. docker-compose loads it for the `ml` and `backend` containers.

# ---- Data-source keys (free tiers; the only ones you must set) ----
# CoinGecko Demo — market cap/supply + community + developer + market data for all 10 coins.
#   Free key, 10k calls/mo, 30/min. Get one at https://www.coingecko.com/en/api
COINGECKO_API_KEY=CG-...
# Etherscan — ETH on-chain. Free key, 5/sec, 100k/day. https://etherscan.io/apis
ETHERSCAN_API_KEY=...

# ---- LLM / RAG (Stage 4) ----
# The Researcher chat + Analyst summary run on a FREE LOCAL Ollama by default (no API key,
# ~€0). Install + pull the two models per docs/OLLAMA_SETUP.md. With Ollama down the backend
# falls back deterministically (chat refuses; Analyst uses template summaries) — demo mode
# works either way. These have sensible defaults in docker-compose.yml; override only to change models.
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_BASE_URL is set by docker-compose to http://host.docker.internal:11434 (the host's
# Ollama, reachable from the backend container); override here only for a non-standard setup.
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# OpenAI — INACTIVE. Spring AI is wired to Ollama (spring.ai.model.*=ollama). The OpenAI starter
# stays on the classpath so switching back is config-only; leave this as-is unless you switch.
OPENAI_API_KEY=not-used

# ---- ML pipeline API (Stage: on-demand ingest/train/predict) ----
# The backend reaches the Python ML service's FastAPI here. docker-compose sets this to the
# compose service name; override only for a non-standard setup (local dev defaults to :8000).
# ML_API_URL=http://ml-api:8000
